# Pine Labs — UAT Credentials
PINE_MERCHANT_ID=your_merchant_id
PINE_CLIENT_ID=your_client_id
PINE_ENV=UAT
PINE_CALLBACK_URL=http://YOUR_EC2_IP/webhooks/pine
PINE_FAILURE_CALLBACK_URL=http://YOUR_EC2_IP/webhooks/pine/failure

# LLM — AWS Bedrock (credentials provided by EC2 IAM Role — no keys needed)
LLM_PROVIDER=bedrock
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-6-v1
AWS_DEFAULT_REGION=us-east-1
# DO NOT add AWS_ACCESS_KEY_ID / SECRET / TOKEN here when using EC2 IAM Role

# CORS — add your Vercel frontend URL here
ALLOWED_ORIGINS=https://your-project.vercel.app

# For local dev with LM Studio instead of Bedrock:
# LLM_PROVIDER=lmstudio
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=qwen3-8b
