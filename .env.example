# Pine Labs — get from dashboard.pluralonline.com
PINE_CLIENT_ID=your_client_id_here
PINE_CLIENT_SECRET=your_client_secret_here
PINE_ENV=UAT
PINE_CALLBACK_URL=http://localhost:8000/webhooks/pine
PINE_FAILURE_CALLBACK_URL=http://localhost:8000/webhooks/pine/failure

# LLM — switch between local LM Studio and AWS Bedrock
# For local testing (default):
LLM_PROVIDER=lmstudio
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen3-8b

# For hackathon hosted run (AWS Bedrock):
# LLM_PROVIDER=bedrock
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
